{
  "name": "@stacklance/envguard-cli",
  "version": "0.1.0",
  "description": "CLI tool for validating, diffing, and managing environment variables",
  "license": "MIT",
  "type": "module",
  "bin": {
    "env-guard": "./dist/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stacklance/envguard-audit": "workspace:*",
    "@stacklance/envguard-core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cli-table3": "^0.6.0"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "zod": "^3.23.0"
  },
  "keywords": ["cli", "env", "environment", "validation", "dotenv"]
}
